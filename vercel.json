{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "framework": "static",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/dist/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/public/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
